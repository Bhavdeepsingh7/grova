# Environment
NODE_ENV=production
PORT=5000

# CORS
CORS_ALLOWLIST=http://localhost:3000,https://your-frontend.example.com

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_TRUSTED_PROXIES=1

# Email settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-or-smtp-password
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=owner@yourdomain.com

# Email retry settings
EMAIL_SEND_TIMEOUT_MS=10000
EMAIL_MAX_RETRIES=2
